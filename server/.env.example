# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=admission_dote
DB_USER=root
DB_PASS=yourpassword

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRE=24h

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_EXPIRE=1

# Environment Variables - TEMPLATE
# Copy this file to .env and fill in actual values
# DO NOT COMMIT .env TO VERSION CONTROL

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MySQL Database Settings
DB_HOST=localhost
DB_PORT=3306
DB_NAME=admission_dote
DB_USER=dote_user
DB_PASS=your_secure_password_here

# Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================
# JWT Token Settings
JWT_SECRET=your_very_secure_secret_key_here_use_strong_random_string
JWT_EXPIRE=24h

# Cookie Settings
COOKIE_EXPIRE=1

# ============================================
# CORS CONFIGURATION
# ============================================
# Frontend URL for CORS
CORS_ORIGIN=http://localhost:5173

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
LOG_DIR=./logs

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@dote-portal.com

# ============================================
# REDIS CONFIGURATION (Optional - for caching)
# ============================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASS=

# ============================================
# THIRD-PARTY SERVICES (Optional)
# ============================================
# Sentry Error Tracking
# SENTRY_DSN=

# AWS S3 for File Storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=

# ============================================
# APPLICATION SETTINGS
# ============================================
# Feature Flags
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_SMS_NOTIFICATIONS=false
FEATURE_TWO_FACTOR_AUTH=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SECURITY SETTINGS
# ============================================
# HTTPS
HTTPS_ENABLED=false

# Bcrypt Salt Rounds (10-12 recommended)
BCRYPT_SALT_ROUNDS=10

# ============================================
# ADMIN INITIAL SETUP
# ============================================
# Initial admin user will be created with these credentials
ADMIN_ID=admin001
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Administrator
